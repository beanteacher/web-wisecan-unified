{
  "name": "wsc",
  "version": "1.0.0",
  "description": "WiseCan CLI — 발송·조회·키·발신번호·설정 14종 명령",
  "bin": {
    "wsc": "./src/index.js"
  },
  "main": "./src/index.js",
  "scripts": {
    "test": "node tests/run_all.js",
    "build:win": "pkg . --target node18-win-x64 --output dist/wsc-win.exe",
    "build:mac": "pkg . --target node18-macos-x64 --output dist/wsc-macos",
    "build:linux": "pkg . --target node18-linux-x64 --output dist/wsc-linux",
    "build:all": "pkg . --targets node18-win-x64,node18-macos-x64,node18-linux-x64 --output dist/wsc"
  },
  "dependencies": {},
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pkg": {
    "scripts": "src/**/*.js",
    "assets": [],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ]
  },
  "keywords": ["wisecan", "sms", "cli", "messaging"],
  "license": "MIT"
}
