              { "id": "channel", "label": "채널 *", "type": "select", "placeholder": "발송 채널 선택" },
              { "id": "body", "label": "본문 *", "type": "textarea", "rows": 5, "placeholder": "메시지 내용을 입력하세요" },
              { "id": "attachment", "label": "첨부 파일", "type": "file-upload", "placeholder": "파일 선택" }
            ],
            "actions": [
              { "label": "발송", "variant": "primary", "width": "100%", "height": "48px" }
            ]
          }
        }
      ]
