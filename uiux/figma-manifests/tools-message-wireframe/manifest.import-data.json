  "frames": [
    {
      "id": "frame-msg-send-pc",
      "name": "Message Send - PC (1440px)",
      "viewport": { "width": 1440, "height": 900 },
      "category": "form",
      "layout": "사이드바(240px) + 콘텐츠 영역. 콘텐츠 내 2컬럼 분할: 좌측 발송 폼(flex-1), 우측 미리보기 패널(360px)",
      "components": ["Sidebar", "PageHeader", "Card", "Input", "Textarea", "Select", "Button", "Badge", "Label", "Separator"],
      "spacing": "sidebar 240px, content padding 32px, form gap-4, card padding 24px",
      "typography": "페이지 제목 H1(24px Bold), 섹션 레이블 Body2(14px Medium), 입력 힌트 Caption(12px)",
      "responsive": "mobile 375px 프레임 별도 — 사이드바 숨김, 탑바 표시, 단일 컬럼 폼",
      "blocks": [
        {
          "id": "send-sidebar",
          "type": "sidebar",
          "activeItem": "message-tools"
        },
        {
          "id": "send-content",
          "type": "content-area",
          "padding": "32px",
          "sections": [
            {
              "id": "send-page-header",
              "type": "page-header",
              "content": {
                "title": "메시지 도구",
                "subtitle": "MCP 채널을 통해 메시지를 발송하고 결과를 확인하세요",
                "tabs": [
                  { "id": "send", "label": "메시지 발송", "active": true },
                  { "id": "history", "label": "발송 이력", "active": false }
                ]
              },
              "spacing": { "mb": "24px" }
            },
            {
              "id": "send-form-area",
              "type": "two-column-layout",
              "gap": "24px",
              "left": {
                "flex": 1,
                "id": "send-form-card",
                "type": "form-card",
                "bg": "#FFFFFF",
                "border": "1px solid #E2E8F0",
                "borderRadius": "12px",
                "padding": "24px",
                "content": {
                  "title": "메시지 발송",
                  "fields": [
                    {
                      "id": "recipient",
                      "label": "수신자 *",
                      "type": "text",
                      "placeholder": "예) user@example.com 또는 @slack-user",
                      "hint": "이메일, Slack 핸들, 전화번호 등 채널별 수신자 식별자",
                      "required": true
                    },
                    {
                      "id": "channel",
                      "label": "채널 *",
                      "type": "select",
                      "placeholder": "발송 채널을 선택하세요",
                      "required": true,
                      "options": [
                        { "value": "email", "label": "이메일" },
                        { "value": "slack", "label": "Slack" },
                        { "value": "sms", "label": "SMS" },
                        { "value": "kakao", "label": "카카오톡" }
                      ]
                    },
                    {
                      "id": "subject",
                      "label": "제목",
                      "type": "text",
                      "placeholder": "예) [Wisecan] 알림 메시지",
                      "hint": "이메일 채널에서만 사용됩니다",
                      "conditionalShow": "channel === 'email'"
                    },
                    {
                      "id": "body",
                      "label": "본문 *",
                      "type": "textarea",
                      "placeholder": "발송할 메시지 내용을 입력하세요. 최대 2,000자까지 입력 가능합니다.",
                      "hint": "남은 글자수 표시: 1,847 / 2,000",
                      "rows": 6,
                      "required": true
                    },
                    {
                      "id": "attachment",
                      "label": "첨부 파일",
                      "type": "file-upload",
                      "placeholder": "파일을 드래그하거나 클릭하여 업로드",
                      "hint": "PDF, PNG, JPG, DOCX 지원. 파일당 최대 10MB",
                      "accept": ".pdf,.png,.jpg,.docx",
                      "maxSize": "10MB",
                      "multiple": false
                    }
                  ],
                  "errorState": {
                    "visible": false,
                    "message": "수신자 이메일 형식이 올바르지 않습니다",
                    "icon": "AlertCircle",
                    "style": {
                      "bg": "#FEF2F2",
                      "border": "1px solid #FECACA",
                      "text": "#DC2626",
                      "borderRadius": "8px",
                      "padding": "12px 16px"
                    }
                  },
                  "actions": [
                    { "label": "발송", "variant": "primary", "icon": "Send", "height": "44px", "loadingLabel": "발송 중..." },
                    { "label": "초기화", "variant": "ghost", "height": "44px" }
                  ]
                }
              },
              "right": {
                "width": "360px",
                "id": "send-preview-card",
                "type": "preview-card",
                "bg": "#FFFFFF",
                "border": "1px solid #E2E8F0",
                "borderRadius": "12px",
                "padding": "24px",
                "content": {
                  "title": "미리보기",
                  "emptyState": {
                    "icon": "MessageSquare",
                    "title": "내용을 입력하면 미리보기가 표시됩니다",
                    "subtitle": "채널, 수신자, 본문을 입력해보세요",
                    "bg": "#F8FAFC",
                    "borderRadius": "8px",
                    "padding": "32px 24px"
                  },
                  "previewContent": {
                    "channelBadge": { "label": "이메일", "variant": "blue" },
                    "recipient": "kim@example.com",
                    "subject": "[Wisecan] 알림 메시지",
                    "body": "안녕하세요. Wisecan에서 보내드리는 알림입니다.",
                    "attachmentCount": 0
                  }
                }
              }
            }
          ]
        }
      ]
    },

    {
